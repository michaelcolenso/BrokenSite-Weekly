# BrokenSite-Weekly Environment Variables
# Copy this file to .env and fill in your values

# === Gumroad API ===
# Get your access token from: https://app.gumroad.com/settings/advanced#application-form
GUMROAD_ACCESS_TOKEN=your_gumroad_access_token_here

# Your existing subscription product ID (from product URL or API)
GUMROAD_PRODUCT_ID=your_product_id_here

# Optional: Multi-product setup (JSON mapping)
# Example: {"basic":"prod_basic_id","pro":"prod_pro_id"}
GUMROAD_PRODUCTS_JSON=
GUMROAD_PRO_SEAT_CAP=5

# === Weekly Scrape Grid ===
# JSON lists let operators expand the launch grid after timing dry runs.
SEARCH_QUERIES_JSON='["plumber", "electrician", "dentist"]'
TARGET_CITIES_JSON='["Austin, TX", "Denver, CO", "Phoenix, AZ"]'
# Card detail extraction dominates Maps runtime on the VPS.
SCRAPER_MAX_RESULTS_PER_QUERY=25

# === Optional Scoring Probes ===
# Image and social-link probes add outbound HEAD requests per scored site.
BROKEN_IMAGE_CHECK_ENABLED=false
DEAD_SOCIAL_CHECK_ENABLED=false

# === Google PageSpeed Insights (opt-in) ===
# Free tier: 25,000 requests/day. Get a key at:
# https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_ENABLED=false
PAGESPEED_API_KEY=

# === Yelp Cross-Reference (opt-in, no API key) ===
# Uses Playwright to scrape Yelp for business verification.
# Adds scoring signals for low Yelp ratings and review count mismatches.
# Longer runtime — capped at YELP_MAX_LEADS per run.
YELP_ENABLED=false
YELP_MAX_LEADS=25

# === SMTP Email Delivery ===
# Gmail example (use App Password, not your regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_FROM_NAME=BrokenSite Weekly

# === Portal ===
PORTAL_SECRET=your_portal_secret_here
PORTAL_BASE_URL=https://your-tracking-domain.com
PORTAL_TOKEN_TTL_DAYS=30

# Operator dashboard secret. The tracking server's / and /dashboard views
# expose lead data and a log tail, so they are disabled (HTTP 403) unless this
# is set. Access the dashboard at https://your-tracking-domain.com/?token=...
DASHBOARD_TOKEN=

# === Outreach ===
# Opt in after tracking and compliance settings are deployed.
OUTREACH_ENABLED=false
OUTREACH_MAX_EMAILS_PER_DAY=300
OUTREACH_MAX_EMAILS_PER_HOUR=60
OUTREACH_DELAY_MIN_SECONDS=15
OUTREACH_DELAY_MAX_SECONDS=45
OUTREACH_SEND_START_HOUR=8
OUTREACH_SEND_END_HOUR=18
OUTREACH_MIN_SCORE=50
OUTREACH_MIN_CONFIDENCE=0.7
OUTREACH_PHYSICAL_ADDRESS=
OUTREACH_COMPANY_NAME=BrokenSite Weekly
TRACKING_BASE_URL=https://your-tracking-domain.com
